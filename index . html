<!DOCTYPE html>
<html>
<head>
  <title>EyeTech Smart Energy</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body style="
  background: linear-gradient(135deg,#0f172a,#1e293b);
  color:white;
  font-family: system-ui;
  text-align:center;
  padding:20px;
">

<h1>⚡ EyeTech Smart Energy</h1>

<div id="app"></div>

<script>

// 🔐 USER ID
let userId = localStorage.getItem("user_id");

if (!userId) {
  userId = "user_" + Math.random().toString(36).substr(2, 9);
  localStorage.setItem("user_id", userId);
}

const surveyDone = localStorage.getItem("survey_done");
const app = document.getElementById("app");


// 🧾 SURVEY
function showSurvey() {
  app.innerHTML = `
    <div style="max-width:400px;margin:auto;background:#111827;padding:20px;border-radius:16px;">
      <h2>🏠 Setup Your Home</h2>

      <input id="price" placeholder="Price per kWh (e.g. 0.31)" /><br><br>
      <input id="lights" placeholder="Number of lights" /><br><br>
      <input id="tv_hours" placeholder="TV hours per day" /><br><br>
      <input id="washing" placeholder="Washing per week" /><br><br>

      <button onclick="submitSurvey()">Continue</button>
    </div>
  `;
}


// 📤 SEND SURVEY
async function submitSurvey() {

  const survey = {
    user_id: userId,
    price_per_kwh: parseFloat(document.getElementById("price").value),
    lights_count: parseInt(document.getElementById("lights").value),
    tv_hours: parseFloat(document.getElementById("tv_hours").value),
    washing_per_week: parseInt(document.getElementById("washing").value),
    devices: ["fridge","tv","lights"]
  };

  try {
    const res = await fetch("https://eye-tech-server.onrender.com/survey", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify(survey)
    });

    if (res.ok) {
      localStorage.setItem("survey_done","true");
      location.reload();
    } else {
      alert("Error saving survey");
    }

  } catch {
    alert("Connection error ❌");
  }
}


// 📊 DASHBOARD
function showDashboard() {
  app.innerHTML = `
    <div style="max-width:600px;margin:auto;background:#111827;padding:20px;border-radius:16px;">

      <h2>📊 Your Energy Dashboard</h2>

      <h3 id="voltage">Voltage: --</h3>
      <h3 id="current">Current: --</h3>
      <h3 id="power">Power: --</h3>

      <hr>

      <h3 id="daily_kwh">Daily Usage: -- kWh</h3>
      <h3 id="monthly_kwh">Monthly Usage: -- kWh</h3>
      <h3 id="daily_cost">Daily Cost: --</h3>
      <h3 id="monthly_cost">Monthly Cost: --</h3>

      <div id="insights"></div>

      <canvas id="chart"></canvas>

    </div>
  `;

  startData();
}


// 📈 GRAPH
let chart;
let powerData = [];
let labels = [];

function initChart() {
  const ctx = document.getElementById("chart").getContext("2d");

  chart = new Chart(ctx, {
    type: "line",
    data: {
      labels: labels,
      datasets: [{
        label: "Power (W)",
        data: powerData,
        borderColor: "cyan"
      }]
    }
  });
}


// 🔄 FETCH DATA
async function fetchData() {

  try {
    const res = await fetch(`https://eye-tech-server.onrender.com/latest/${userId}`);
    const data = await res.json();

    if (data.error) return;

    document.getElementById("voltage").innerText = "Voltage: " + data.voltage + " V";
    document.getElementById("current").innerText = "Current: " + data.current + " A";
    document.getElementById("power").innerText = "Power: " + data.power + " W";

    // ✅ NEW: kWh + cost
    document.getElementById("daily_kwh").innerText =
      "Daily Usage: " + data.estimated_daily_kwh + " kWh";

    document.getElementById("monthly_kwh").innerText =
      "Monthly Usage: " + data.estimated_monthly_kwh + " kWh";

    document.getElementById("daily_cost").innerText =
      "Daily Cost: $" + data.daily_cost;

    document.getElementById("monthly_cost").innerText =
      "Monthly Cost: $" + data.monthly_cost;

    // 🧠 insights
    const ins = document.getElementById("insights");
    ins.innerHTML = "<h3>🧠 AI Insights</h3>";

    data.insights.forEach(i => {
      ins.innerHTML += "<p>" + i + "</p>";
    });

    // 📈 graph
    const time = new Date().toLocaleTimeString();
    labels.push(time);
    powerData.push(data.power);

    if (labels.length > 20) {
      labels.shift();
      powerData.shift();
    }

    chart.update();

  } catch {
    console.log("fetch error");
  }
}


// ▶️ START
function startData() {
  initChart();
  fetchData();
  setInterval(fetchData, 5000);
}


// 🚀 INIT
if (!surveyDone) showSurvey();
else showDashboard();

</script>

</body>
</html>
