<!DOCTYPE html>
<html>
<head>
  <title>EyeTech</title>
</head>

<body style="background:#0f172a;color:white;text-align:center;font-family:sans-serif;">

<h1>⚡ EyeTech</h1>
<div id="app"></div>

<script>

let userId = localStorage.getItem("user_id");

if (!userId) {
  userId = "user_" + Math.random().toString(36).substr(2,9);
  localStorage.setItem("user_id", userId);
}

const surveyDone = localStorage.getItem("survey_done");
const app = document.getElementById("app");

// 🧾 SURVEY
function showSurvey(){
  app.innerHTML = `
    <h2>Setup</h2>
    <input id="price" placeholder="Price per kWh"><br><br>
    <input id="lights" placeholder="Lights count"><br><br>
    <button onclick="submitSurvey()">Start</button>
  `;
}

async function submitSurvey(){
  await fetch("https://eye-tech-server.onrender.com/survey", {
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      user_id:userId,
      price_per_kwh:parseFloat(price.value),
      lights_count:parseInt(lights.value),
      devices:["fridge","tv","lights"]
    })
  });

  localStorage.setItem("survey_done",true);
  location.reload();
}

// 📊 DASHBOARD
function showDashboard(){
  app.innerHTML = `
    <h2>Dashboard</h2>

    <h3 id="daily"></h3>
    <h3 id="monthly"></h3>
    <h3 id="cost"></h3>

    <h3>Devices</h3>
    <label><input type="checkbox" onchange="toggle('lights',this)"> Lights</label><br>
    <label><input type="checkbox" onchange="toggle('tv',this)"> TV</label><br>
    <label><input type="checkbox" onchange="toggle('washing_machine',this)"> Washing</label><br>

    <div id="insights"></div>
  `;

  setInterval(fetchData,5000);
}

// 🔌 TOGGLE
async function toggle(device, el){

  let flags = JSON.parse(localStorage.getItem("usage_flags")||"{}");
  flags[device] = el.checked;

  localStorage.setItem("usage_flags", JSON.stringify(flags));

  await fetch("https://eye-tech-server.onrender.com/usage",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      user_id:userId,
      usage_flags:flags
    })
  });

  await fetch("https://eye-tech-server.onrender.com/track",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      user_id:userId,
      device:device,
      action: el.checked ? "on":"off"
    })
  });
}

// 🔄 FETCH DATA
async function fetchData(){

  const res = await fetch(`https://eye-tech-server.onrender.com/latest/${userId}`);
  const data = await res.json();

  daily.innerText = "Daily kWh: " + data.daily_kwh;
  monthly.innerText = "Monthly kWh: " + data.monthly_kwh;
  cost.innerText = "Monthly Cost: $" + data.monthly_cost;

  insights.innerHTML = "<h3>Insights</h3>";
  data.insights.forEach(i => insights.innerHTML += "<p>"+i+"</p>");
}

// 🚀 INIT
if(!surveyDone) showSurvey();
else showDashboard();

</script>

</body>
</html>
