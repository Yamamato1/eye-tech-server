<!DOCTYPE html>
<html>
<body style="background:#0f172a;color:white;text-align:center;font-family:sans-serif;">

<h1>⚡ EyeTech</h1>
<div id="app"></div>

<script>

let userId = localStorage.getItem("user_id") || "user_"+Math.random();
localStorage.setItem("user_id", userId);

const app = document.getElementById("app");

function showSurvey(){
  app.innerHTML = `
    <input id="price" placeholder="kWh price"><br>
    <input id="lights" placeholder="lights"><br>
    <button onclick="submit()">Start</button>`;
}

async function submit(){
  await fetch("/survey",{method:"POST",headers:{"Content-Type":"application/json"},
  body:JSON.stringify({
    user_id:userId,
    price_per_kwh:+price.value,
    lights_count:+lights.value
  })});

  localStorage.setItem("survey_done",1);
  location.reload();
}

function showDash(){
  app.innerHTML=`
  <h3 id="daily"></h3>
  <h3 id="cost"></h3>
  <h3 id="peak"></h3>

  <label><input type="checkbox" onchange="t('lights',this)">lights</label><br>
  <label><input type="checkbox" onchange="t('tv',this)">tv</label><br>
  <label><input type="checkbox" onchange="t('washing_machine',this)">wash</label>

  <div id="ins"></div>
  <div id="week"></div>
  `;

  setInterval(load,3000);
}

async function t(d,e){
  await fetch("/track",{method:"POST",headers:{"Content-Type":"application/json"},
  body:JSON.stringify({user_id:userId,device:d,action:e.checked?"on":"off"})});
}

async function load(){
  let r=await fetch("/latest/"+userId);
  let d=await r.json();

  daily.innerText="Daily: "+d.daily_kwh;
  cost.innerText="Cost: "+d.monthly_cost;
  peak.innerText="Peak: "+d.peak_hour;

  ins.innerHTML="";
  d.insights.forEach(i=>ins.innerHTML+=`<p>${i}</p>`);

  week.innerHTML="";
  for(let k in d.week){
    week.innerHTML+=`<p>${k}: ${d.week[k]}</p>`;
  }
}

if(localStorage.getItem("survey_done")) showDash();
else showSurvey();

</script>
</body>
</html>
